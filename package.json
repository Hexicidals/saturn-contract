{
  "name": "pump-fees-to-jupiter-perps",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "anchor build",
    "cli": "ts-node client/cli.ts",
    "test": "npm run test:anchor",
    "test:anchor": "anchor build && if [ -f target/sbpf-solana-solana/release/pump_fees_to_jupiter_perps.so ]; then cp target/sbpf-solana-solana/release/pump_fees_to_jupiter_perps.so target/deploy/pump_fees_to_jupiter_perps.so; fi && COPYFILE_DISABLE=1 anchor test --skip-build",
    "test:rust": "cargo test -p pump-fees-to-jupiter-perps",
    "test:ts": "mocha -r ts-node/register tests/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.13",
    "@solana/web3.js": "^1.98.4",
    "commander": "^14.0.2",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.1",
    "chai": "^5.3.3",
    "mocha": "^11.7.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
